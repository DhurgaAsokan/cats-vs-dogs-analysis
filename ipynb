{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPyRa81Y3bycoHY3CLTyreH"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["# =====================================\n","# CATS VS DOGS DATASET ANALYSIS\n","# =====================================\n","\n","import zipfile\n","import os\n","import matplotlib.pyplot as plt\n","from PIL import Image\n","\n","# Extract ZIP File\n","zip_file = \"data.zip\"\n","\n","with zipfile.ZipFile(zip_file, 'r') as zip_ref:\n","    zip_ref.extractall(\"dataset\")\n","\n","print(\"Dataset Extracted Successfully!\")\n","\n","# Count Images\n","cat_count = 0\n","dog_count = 0\n","\n","cat_images = []\n","dog_images = []\n","\n","for root, dirs, files in os.walk(\"dataset\"):\n","    for file in files:\n","        if file.lower().endswith(('.jpg', '.jpeg', '.png')):\n","            full_path = os.path.join(root, file)\n","\n","            if \"cat\" in file.lower():\n","                cat_count += 1\n","                cat_images.append(full_path)\n","\n","            elif \"dog\" in file.lower():\n","                dog_count += 1\n","                dog_images.append(full_path)\n","\n","print(\"\\nNumber of Cat Images :\", cat_count)\n","print(\"Number of Dog Images :\", dog_count)\n","\n","# Display Sample Cat Image\n","if len(cat_images) > 0:\n","    img = Image.open(cat_images[0])\n","\n","    plt.figure(figsize=(4,4))\n","    plt.imshow(img)\n","    plt.axis(\"off\")\n","    plt.title(\"Sample Cat Image\")\n","    plt.show()\n","\n","# Display Sample Dog Image\n","if len(dog_images) > 0:\n","    img = Image.open(dog_images[0])\n","\n","    plt.figure(figsize=(4,4))\n","    plt.imshow(img)\n","    plt.axis(\"off\")\n","    plt.title(\"Sample Dog Image\")\n","    plt.show()\n","\n","# Bar Chart\n","plt.figure(figsize=(6,4))\n","plt.bar([\"Cats\", \"Dogs\"], [cat_count, dog_count])\n","plt.title(\"Cats vs Dogs Dataset\")\n","plt.ylabel(\"Number of Images\")\n","plt.show()\n","\n","# Pie Chart\n","plt.figure(figsize=(6,6))\n","plt.pie(\n","    [cat_count, dog_count],\n","    labels=[\"Cats\", \"Dogs\"],\n","    autopct='%1.1f%%'\n",")\n","plt.title(\"Cats vs Dogs Distribution\")\n","plt.show()\n","\n","print(\"\\nProject Completed Successfully!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"FaCcKJhMFc7N","executionInfo":{"status":"ok","timestamp":1780399604844,"user_tz":-330,"elapsed":1050,"user":{"displayName":"Dhurga Dhurga","userId":"16157572654272406034"}},"outputId":"ef023629-1a61-4b19-f0b2-135ede9a3f51"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Dataset Extracted Successfully!\n","\n","Number of Cat Images : 1011\n","Number of Dog Images : 1012\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 400x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 400x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Project Completed Successfully!\n"]}]},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Fa_FWu-XHYJj","executionInfo":{"status":"ok","timestamp":1780400199099,"user_tz":-330,"elapsed":31270,"user":{"displayName":"Dhurga Dhurga","userId":"16157572654272406034"}},"outputId":"0761235e-404d-4a96-ae2c-7fc7219fbf87"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]}]}